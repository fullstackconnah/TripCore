# TripCore — Portainer Stack Environment Variables
# Copy these into Portainer stack env settings (do NOT commit actual values)

# Required — no defaults, stack will not start without these
POSTGRES_PASSWORD=<strong-password-16-chars-min>
JWT_SECRET=<random-32-char-string>
ALLOWED_ORIGINS=http://<your-server-address>:8475

# Optional — defaults shown
ASPNETCORE_ENVIRONMENT=Production